<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DesktopGremlin.MainPage"
             BackgroundColor="Transparent"  
              IsVisible="True"  
             Opacity="1"
             >
    <VerticalStackLayout Padding="5">
        <Image x:Name="BotImage" Source="neutral.png" VerticalOptions="Center" />

        <ScrollView VerticalOptions="FillAndExpand">
            <VerticalStackLayout x:Name="MessagesContainer" />
        </ScrollView>

        <HorizontalStackLayout Spacing="8">
            <Entry x:Name="UserInput" Placeholder="Type a message..." HorizontalOptions="FillAndExpand" />
            <Button Text="Send" Clicked="OnSendClicked" />
        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>
